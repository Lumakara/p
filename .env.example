# =====================================================
# Environment Variables Example
# -----------------------------------------------------
# Copy this file to ".env" and fill in your own values.
# NEVER commit the real ".env" file or real secrets.
#
# NOTE: Every variable prefixed with VITE_ is embedded
# into the public client bundle and is therefore visible
# to anyone using the app. Do NOT put secrets that must
# stay private (e.g. server-side OpenAI keys) here for a
# production deployment — proxy those through a backend.
# =====================================================

# OpenAI API (for AI Chatbot) - exposed to the client, use a restricted key or a backend proxy
VITE_OPENAI_API_KEY=

# Pakasir Payment Gateway - get from https://app.pakasir.com/dashboard
VITE_PAKASIR_SLUG=your-project-slug
VITE_PAKASIR_API_KEY=your-pakasir-api-key

# Telegram Bot (for notifications)
VITE_TELEGRAM_BOT_TOKEN=your-telegram-bot-token
VITE_TELEGRAM_CHAT_ID=your-telegram-chat-id

# EmailJS (optional)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Google Analytics (optional)
VITE_GA_TRACKING_ID=
