# ==========================================
# DIGITAL STORE - Environment Configuration
# ==========================================
# This is a localStorage-only application.
# No database backend required!
# ==========================================

# ------------------------------------------
# OpenAI API Configuration (for AI Chatbot)
# ------------------------------------------
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-your-openai-api-key

# ------------------------------------------
# Pakasir Payment Gateway Configuration
# ------------------------------------------
# Get from: https://app.pakasir.com/dashboard
VITE_PAKASIR_SLUG=your-store-slug
VITE_PAKASIR_API_KEY=your-pakasir-api-key

# ------------------------------------------
# Telegram Bot Configuration (for notifications)
# ------------------------------------------
# Get Bot Token from: https://t.me/BotFather
# Get Chat ID from: https://t.me/userinfobot
VITE_TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxyz
VITE_TELEGRAM_CHAT_ID=123456789

# ------------------------------------------
# Optional: EmailJS Configuration (optional)
# ------------------------------------------
# Get from: https://dashboard.emailjs.com/admin
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ------------------------------------------
# Optional: Google Analytics (optional)
# ------------------------------------------
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
