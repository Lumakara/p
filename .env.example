# ============================================================
# Digital Store - Environment Variables
# Copy this file to ".env" and fill in your real credentials.
# Never commit ".env" to git.
# ============================================================

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Database: Neon Cloud (PostgreSQL) ----
# Docs: https://neon.com/docs/get-started/full-backend-quickstart
# Use the pooled connection string for DATABASE_URL and the direct one for DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ---- Authentication: Clerk ----
# Docs: https://clerk.com/docs/nextjs/getting-started/quickstart
# IMPORTANT: replace these with your real keys from the Clerk dashboard.
# The publishable key below is a valid-FORMAT dummy (it decodes to
# clerk.example.com) so that `npm run build` / Vercel can prerender pages without
# crashing on an invalid publishable key. It will NOT authenticate real users.
# Replace BOTH with your real keys from the Clerk dashboard before going live.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_Y2xlcmsuZXhhbXBsZS5jb20k"
CLERK_SECRET_KEY="REPLACE_WITH_YOUR_CLERK_SECRET_KEY"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/"
# Comma-separated list of Clerk user IDs that should always be treated as ADMIN.
# (Alternatively set publicMetadata.role = "admin" in the Clerk dashboard.)
ADMIN_USER_IDS=""

# ---- Payment Gateway: RamaShop ----
# Docs: https://ramashop.my.id/docs.html
PAYMENT_BASE_URL="https://ramashop.my.id/api/public"
PAYMENT_API_KEY="rg_your_ramashop_api_key"
# Default payment expiry in minutes for QRIS orders.
PAYMENT_EXPIRY_MINUTES="15"

# ---- AI Chatbot: NeoXR ----
# v1 (Kimi K2): https://api.neoxr.eu/api/kimi
# v2 (Chat GPT-4): https://api.neoxr.eu/api/gpt4
CHATBOT_API_KEY="your_neoxr_api_key"
CHATBOT_BASE_URL="https://api.neoxr.eu/api"
CHATBOT_V1_ENDPOINT="kimi"
CHATBOT_V2_ENDPOINT="gpt4"

# ---- Owner Notifications + Chat Bridge: Telegram Bot ----
# Create a bot via @BotFather and get your chat id (e.g. via @userinfobot).
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
TELEGRAM_CHAT_ID="123456789"
# Secret token used to verify Telegram webhook calls (set when calling setWebhook).
TELEGRAM_WEBHOOK_SECRET="change-me-random-string"

# ---- Captcha: Cloudflare Turnstile ----
NEXT_PUBLIC_CF_TURNSTILE_SITE_KEY="0x4AAAAAAA..."
CF_TURNSTILE_SECRET="0x4AAAAAAA..."

# ---- Media / Image CDN: Cloudinary ----
# Docs: https://next.cloudinary.dev/installation
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
# Optional: an unsigned upload preset for client-side uploads.
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="digital_store_unsigned"
